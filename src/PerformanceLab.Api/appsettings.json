{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "PerformanceLab.Api.Middleware": "Information"
    }
  },
  "AllowedHosts": "*",
  "PerformanceFeatures": {
    "EnableOutputCaching": true,
    "EnableObjectPooling": false,
    "CacheDurationSeconds": 60
  }
}
